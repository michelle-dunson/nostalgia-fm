# Spotify Web API credentials
# Create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3001/api/auth/callback
# Spotify does NOT allow "localhost" — use 127.0.0.1 with http (loopback is OK).
# Add this exact URI in the Spotify Developer Dashboard.
# Open the app at http://127.0.0.1:3001 (not localhost).

# Used to sign OAuth state cookies
SESSION_SECRET=
